# Top-level template. Copy this to backend/.env (or .env in each app) and fill
# in real values. Real .env files are gitignored — never commit them.

# Required: LiteLLM-compatible LLM provider key.
# Default config uses Anthropic Claude.
ANTHROPIC_API_KEY="sk-ant-..."

# Required: Tavily key for the web research agent
TAVILY_API_KEY="tvly-..."

# Optional: override the LiteLLM model id
# Examples:
#   anthropic/claude-3-5-sonnet-latest
#   anthropic/claude-3-5-haiku-latest
#   nvidia/meta/llama-3.3-70b-instruct
# LITELLM_MODEL="anthropic/claude-3-5-sonnet-latest"

# Optional: where ChromaDB persists the RAG corpus
# CHROMA_DB_PATH=".chroma"

# Optional: frontend → backend URL override
# BACKEND_URL="http://localhost:8000"
